// Sonnet 键盘键位映射
// 14个按键 + EC11编码器
// input-gpios 已按物理布局从上到下、从左到右排列
// position 直接对应物理位置
//
// 第1行: pos0=S1  pos1=S2  pos2=S3  pos3=S4  pos4=S5
// 第2行: pos5=S6  pos6=S7  pos7=S8  pos8=S9  pos9=S11 pos10=S12
// 第3行: pos11=S10 pos12=S13 pos13=S14 pos14=S15(编码器按键)

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

// 每次 tick 发送滚动值 1: 63 * 16ms / 1000 = 1.008 → 取整为 1
#define ZMK_POINTING_DEFAULT_SCRL_VAL 63

#include <dt-bindings/zmk/pointing.h>

#define BASE 0
#define FN   1

/ {
    // 自定义编码器行为: 鼠标滚轮
    behaviors {
        scroll_encoder: scroll_encoder {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_UP>, <&msc SCRL_DOWN>;
            tap-ms = <32>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";
            bindings = <
                // 第1行: Q  W  E  R  T
                &kp Q    &kp W    &kp E    &kp R    &kp T
                // 第2行: B  N  A  S  D  F
                &kp B    &kp N    &kp A    &kp S    &kp D    &kp F
                // 第3行: G  H  Z  切层
                &kp G    &kp H    &kp Z    &to FN
            >;

            // 编码器旋转: 音量控制
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        fn_layer {
            display-name = "FN";
            bindings = <
                // 第1行: 1  2  3  4  5
                &kp N1    &kp N2    &kp N3    &kp N4    &kp N5
                // 第2行: B  N  6  7  8  9
                &kp N6     &kp N7     &kp N8    &kp N9    &kp O    &kp P
                // 第3行: 0  -  =  切回·
                &kp N0    &kp MINUS &kp EQUAL &to BASE
            >;

            // 编码器旋转: 鼠标滚轮上下滚动
            sensor-bindings = <&scroll_encoder>;
        };
    };
};
